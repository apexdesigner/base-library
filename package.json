{
  "name": "@apexdesigner/base-library",
  "version": "1.0.158",
  "description": "Apex Designer library that generates Angular + Express applications from strongly typed DSL design files with intellisense. Business objects defined in the DSL drive both server and client generation. The generated server includes CRUD and custom logic, exposed as REST API endpoints, Zod schema generation via schema-tools, and schema-driven persistence with multiple backend options. The client includes Material Design, flex layout, data tables, and schema-driven forms that auto-render based on business object schemas.",
  "keywords": [
    "apex-designer",
    "apex-designer-library",
    "apex-designer-generators"
  ],
  "author": "Dave Engberg",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/apexdesigner/base-library.git"
  },
  "homepage": "https://github.com/apexdesigner/base-library#readme",
  "bugs": {
    "url": "https://github.com/apexdesigner/base-library/issues"
  },
  "main": "design/project/project.json",
  "files": [
    "design/",
    "!design/testing/",
    "generators/",
    "docs/"
  ],
  "optionalDependencies": {
    "@apexbpm/envisioning-studio-cli": "^1.0.5"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "format": "prettier --write \"generators/**\" \"design/**\"",
    "pack": "rm -f apexdesigner-base-library-*.tgz && npm pack"
  },
  "type": "module",
  "devDependencies": {
    "@apexdesigner/claude-skills": "^1.0.48",
    "@apexdesigner/dsl": "^0.8.77",
    "@apexdesigner/generator": "^0.8.54",
    "@apexdesigner/server": "^0.8.51",
    "@apexdesigner/utilities": "^0.1.27",
    "@apexdesigner/validator": "^0.8.59",
    "@types/debug": "^4.1.12",
    "@types/node": "^25.2.3",
    "change-case": "^5.4.4",
    "prettier": "^3.8.1",
    "ts-morph": "^27.0.2",
    "vitest": "^4.0.18"
  },
  "bin": {
    "api": ".claude/skills/apex-designer/scripts/api.cjs"
  }
}
